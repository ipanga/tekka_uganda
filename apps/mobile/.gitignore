app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Firebase Android config — contains a Google API key flagged by GitHub
# secret scanning. Excluded from version control; prod release CI injects
# from the GOOGLE_SERVICES_JSON secret. Dev/staging builds skip the
# google-services plugin entirely (see android/app/build.gradle.kts), so
# they don't need the file. For local prod builds, download from
# Firebase Console into android/app/src/prod/google-services.json.
#
# The iOS equivalent (ios/Runner/GoogleService-Info.plist) stays committed
# as a placeholder with fake values because Xcode requires the file to
# exist for bundling; the real plist is injected at release-build time.
android/app/src/prod/google-services.json
